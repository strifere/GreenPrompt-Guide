generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============= ENUMS =============

enum TacticType {
  GREEN_PRACTICE
  RED_PRACTICE
}

enum DataFormatType {
  TEXT_ONLY
  IMAGE
  PDF
  CSV
  HTML
  ANY_FORMAT
}

enum EnergyMetricType {
  REDUCTION
  CONSUMPTION
  EFFICIENCY
}

enum AccuracyLevel {
  WORSE
  SAME
  SAME_OR_BETTER
  BETTER
  MUCH_BETTER
  NEAR_PERFECT
}

enum MetricSubtype {
  ENERGY
  ACCURACY
  GENERIC
}

enum StudyType {
  EMPIRICAL_STUDY
  CASE_STUDY
  COMPARATIVE_STUDY
  DESIGN_SCIENCE_RESEARCH
  OTHER
}

// ============= MAIN ENTITIES =============

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  tactic      TacticType
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  practices PracticeCategory[]

  @@map("categories")
}

model Practice {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  verifiedAt  DateTime?

  // Relationships
  categories      PracticeCategory[]
  energyMetrics   EnergyMetric[]
  accuracyMetrics AccuracyMetric[]
  examples        PracticeExample[]
  models          PracticeModel[]
  papers          PaperPractice[]
  prompts         PracticePromptTechnique[]

  @@map("practices")
}

model PracticeCategory {
  practiceId Int
  categoryId Int
  createdAt  DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([practiceId, categoryId])
  @@map("practice_categories")
}

model EnergyMetric {
  metricId       Int              @id
  practiceId     Int
  type           EnergyMetricType
  minValue       Float?
  maxValue       Float?
  bestGuessValue Float?
  unit           String           @default("PERCENTAGE")

  metric   Metric   @relation(fields: [metricId], references: [id], onDelete: Cascade)
  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("energy_metrics")
}

model AccuracyMetric {
  metricId   Int           @id
  practiceId Int
  level      AccuracyLevel
  score      Float? // Numeric representation 0-1

  metric   Metric   @relation(fields: [metricId], references: [id], onDelete: Cascade)
  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("accuracy_metrics")
}

model PracticeExample {
  id              Int      @id @default(autoincrement())
  practiceId      Int
  scenario        String
  originalPrompts String // Can be very long text
  improvedPrompts String
  observations    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("practice_examples")
}

model PromptTechnique {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  example     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practices PracticePromptTechnique[]

  @@map("prompt_techniques")
}

model PracticePromptTechnique {
  practiceId        Int
  promptTechniqueId Int
  createdAt         DateTime @default(now())

  practice        Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  promptTechnique PromptTechnique @relation(fields: [promptTechniqueId], references: [id], onDelete: Cascade)

  @@id([practiceId, promptTechniqueId])
  @@map("practice_prompt_techniques")
}

model Model {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  parameters  String? // e.g., "7B", "13B"
  dataFormat  DataFormatType @default(TEXT_ONLY)
  size        String? // e.g., "small", "large"
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  practices PracticeModel[]

  @@map("models")
}

model PracticeModel {
  practiceId Int
  modelId    Int
  createdAt  DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  model    Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@id([practiceId, modelId])
  @@map("practice_models")
}

model Dataset {
  id             Int            @id @default(autoincrement())
  name           String         @unique
  description    String?
  size           String? // e.g., "625 items", "large"
  dataFormatType DataFormatType @default(TEXT_ONLY)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  papers PaperDataset[]

  @@map("datasets")
}

model Reference {
  id               Int       @id @default(autoincrement())
  title            String
  authors          String
  abstract         String?
  keywords         String? // comma-separated or JSON
  year             Int
  studyType        StudyType
  domain           String?
  task             String?
  venue            String? // conference, journal, arxiv, etc.
  toolAvailability String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  practices       PaperPractice[]
  datasets        PaperDataset[]
  hyperparameters PaperHyperparameter[]

  @@map("references")
}

model PaperPractice {
  practiceId  Int
  referenceId Int
  createdAt   DateTime @default(now())

  practice  Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  reference Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([practiceId, referenceId])
  @@map("paper_practices")
}

model PaperDataset {
  datasetId   Int
  referenceId Int
  createdAt   DateTime @default(now())

  dataset   Dataset   @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  reference Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([datasetId, referenceId])
  @@map("paper_datasets")
}

model Hyperparameter {
  id        Int      @id @default(autoincrement())
  name      String
  value     String // Flexible for various types
  dataType  String // "string", "float", "int", "boolean"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  papers PaperHyperparameter[]

  @@unique([name, value])
  @@map("hyperparameters")
}

model PaperHyperparameter {
  referenceId      Int
  hyperparameterId Int
  createdAt        DateTime @default(now())

  reference      Reference      @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  hyperparameter Hyperparameter @relation(fields: [hyperparameterId], references: [id], onDelete: Cascade)

  @@id([referenceId, hyperparameterId])
  @@map("paper_hyperparameters")
}

model Metric {
  id          Int           @id @default(autoincrement())
  subtype     MetricSubtype @default(GENERIC)
  title       String?
  value       String? // Can be numeric or text
  description String?
  confidence  Float? // Certainty of measurement (0.0 to 1.0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  energyMetric   EnergyMetric?
  accuracyMetric AccuracyMetric?

  @@map("metrics")
}
