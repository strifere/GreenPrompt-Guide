generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============= ENUMS =============

enum TacticType {
  GREEN_PRACTICE
  RED_PRACTICE
}

enum DataFormatType {
  TEXT_ONLY
  IMAGE
  PDF
  CSV
  HTML
  ANY_FORMAT
}

enum EnergyMetricType {
  REDUCTION
  CONSUMPTION
  EFFICIENCY
}

enum AccuracyLevel {
  WORSE
  SAME_OR_WORSE
  SAME
  SAME_OR_BETTER
  BETTER
  MUCH_BETTER
  NEAR_PERFECT
}

enum MetricSubtype {
  ENERGY
  ACCURACY
  GENERIC
}

enum UserRole {
  USER
  ADMIN
}

// ============= MAIN ENTITIES =============

model User {
  username  String   @id
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  banned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  name        String     @id
  description String?
  tactic      TacticType
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  practices PracticeCategory[]

  @@map("categories")
}

model Practice {
  name        String     @id
  description String
  greenScore  Int        @default(50)
  tactic      TacticType @default(GREEN_PRACTICE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  verifiedAt  DateTime?

  // Relationships
  categories       PracticeCategory[]
  models           PracticeModel[]
  papers           PaperPractice[]
  prompts          PracticePromptTechnique[]
  practiceExamples PracticeExample[]
  hyperparameters  Hyperparameter[]
  metrics          Metric[]

  @@map("practices")
}

model PracticeExample {
  id              Int      @id @default(autoincrement())
  practiceName    String
  scenario        String
  originalPrompts String // Can be very long text
  improvedPrompts String
  observations    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationship stored only here (disjoint: PracticeExample is specific to one Practice)
  practice Practice @relation(fields: [practiceName], references: [name], onDelete: Cascade)

  @@map("practice_examples")
}

model PromptTechnique {
  name        String   @id
  description String
  example     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practices  PracticePromptTechnique[]
  references PaperPromptTechnique[]

  @@map("prompt_techniques")
}

model Model {
  name           String           @id
  description    String?
  parameters     String? // e.g., "7B", "13B"
  dataFormatType DataFormatType[] @default([TEXT_ONLY])
  size           String? // e.g., "small", "large"
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  practices  PracticeModel[]
  references ModelReference[]

  @@map("models")
}

model Dataset {
  name           String           @id
  description    String?
  size           String? // e.g., "625 items", "large"
  dataFormatType DataFormatType[] @default([TEXT_ONLY])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  papers PaperDataset[]

  @@map("datasets")
}

model Reference {
  title            String   @id
  authors          String
  abstract         String?
  keywords         String? // comma-separated or JSON
  year             Int
  studyType        String
  domain           String?
  task             String?
  venue            String? // conference, journal, arxiv, etc.
  toolAvailability String?
  link             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  practices        PaperPractice[]
  datasets         PaperDataset[]
  promptTechniques PaperPromptTechnique[]
  hyperparameters  Hyperparameter[]
  models           ModelReference[]

  @@map("references")
}

model Hyperparameter {
  id             Int      @id @default(autoincrement())
  referenceTitle String
  practiceName   String?
  name           String
  value          String // Flexible for various types
  dataType       String // "string", "float", "int", "boolean"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationship stored only here (disjoint: Hyperparameter belongs to exactly one Reference)
  reference Reference @relation(fields: [referenceTitle], references: [title], onDelete: Cascade)
  practice  Practice? @relation(fields: [practiceName], references: [name], onDelete: SetNull)

  @@unique([name, value, referenceTitle])
  @@map("hyperparameters")
}

model Metric {
  id           Int           @id @default(autoincrement())
  subtype      MetricSubtype @default(GENERIC)
  title        String
  value        String // Can be numeric or text
  description  String?
  confidence   Float // Certainty of measurement (0.0 to 1.0)
  practiceName String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  practice        Practice         @relation(fields: [practiceName], references: [name], onDelete: Cascade)
  energyMetrics   EnergyMetric[]
  accuracyMetrics AccuracyMetric[]

  @@map("metrics")
}

model EnergyMetric {
  metricId       Int              @id
  type           EnergyMetricType
  minValue       Float?
  maxValue       Float?
  bestGuessValue Float
  unit           String           @default("PERCENTAGE")

  metric Metric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@map("energy_metrics")
}

model AccuracyMetric {
  metricId Int           @id
  level    AccuracyLevel
  score    Float? // Numeric representation 0-1

  metric Metric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@map("accuracy_metrics")
}

// ============= ASSOCIATIVE TABLES =============

model PracticeCategory {
  practiceName String
  categoryName String
  createdAt    DateTime @default(now())

  practice Practice @relation(fields: [practiceName], references: [name], onDelete: Cascade)
  category Category @relation(fields: [categoryName], references: [name], onDelete: Cascade)

  @@id([practiceName, categoryName])
  @@map("practice_categories")
}

model PracticePromptTechnique {
  practiceName        String
  promptTechniqueName String
  createdAt           DateTime @default(now())

  practice        Practice        @relation(fields: [practiceName], references: [name], onDelete: Cascade)
  promptTechnique PromptTechnique @relation(fields: [promptTechniqueName], references: [name], onDelete: Cascade)

  @@id([practiceName, promptTechniqueName])
  @@map("practice_prompt_techniques")
}

model PracticeModel {
  practiceName String
  modelName    String
  createdAt    DateTime @default(now())

  practice Practice @relation(fields: [practiceName], references: [name], onDelete: Cascade)
  model    Model    @relation(fields: [modelName], references: [name], onDelete: Cascade)

  @@id([practiceName, modelName])
  @@map("practice_models")
}

model ModelReference {
  modelName      String
  referenceTitle String
  createdAt      DateTime @default(now())

  model     Model     @relation(fields: [modelName], references: [name], onDelete: Cascade)
  reference Reference @relation(fields: [referenceTitle], references: [title], onDelete: Cascade)

  @@id([modelName, referenceTitle])
  @@map("model_references")
}

model PaperPractice {
  practiceName   String
  referenceTitle String
  createdAt      DateTime @default(now())

  practice  Practice  @relation(fields: [practiceName], references: [name], onDelete: Cascade)
  reference Reference @relation(fields: [referenceTitle], references: [title], onDelete: Cascade)

  @@id([practiceName, referenceTitle])
  @@map("paper_practices")
}

model PaperDataset {
  datasetName    String
  referenceTitle String
  createdAt      DateTime @default(now())

  dataset   Dataset   @relation(fields: [datasetName], references: [name], onDelete: Cascade)
  reference Reference @relation(fields: [referenceTitle], references: [title], onDelete: Cascade)

  @@id([datasetName, referenceTitle])
  @@map("paper_datasets")
}

model PaperPromptTechnique {
  promptTechniqueName String
  referenceTitle      String
  createdAt           DateTime @default(now())

  promptTechnique PromptTechnique @relation(fields: [promptTechniqueName], references: [name], onDelete: Cascade)
  reference       Reference       @relation(fields: [referenceTitle], references: [title], onDelete: Cascade)

  @@id([promptTechniqueName, referenceTitle])
  @@map("paper_prompt_techniques")
}
